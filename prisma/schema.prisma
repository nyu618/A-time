datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  lineUid     String   @id
  displayName String?
  visitCount  Int      @default(0)
  queues      Queue[]
}

model Queue {
  id          Int      @id @default(autoincrement())
  lineUserId  String
  user        User?    @relation(fields: [lineUserId], references: [lineUid])
  displayName String?
  status      String   @default("WAITING") // WAITING, CALLED, IN_STORE, ASSESSING, COMPLETED, CANCELED
  targetDate  String   @default("") // e.g. "2023-10-01"
  dailyNumber Int      @default(0)
  cancelCount Int      @default(0)
  createdAt   DateTime @default(now())
  calledAt    DateTime?
}
